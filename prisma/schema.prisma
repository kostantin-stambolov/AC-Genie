// AC-Genie: American College Preparation – simple schema
// SQLite for local dev; switch to Postgres in production if needed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  pinHash   String
  createdAt DateTime @default(now())
  sessions  Session[]
  attempts  Attempt[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Attempt {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  part        Int       // 1 = Essay, 2 = Test
  section     Int?      // null for Part 1; 1–4 for Part 2
  status      String    // "in_progress" | "completed"
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  promptText       String?   // Part 1: chosen essay prompt
  essayBody        String?   // Part 1: student's essay text
  lastFeedbackGrade          Int?      // Part 1: final score 0–40 (was 2–6 in old scoring)
  lastFeedbackScoreBreakdown String?   // Part 1: JSON: {"examiner1":{...},"examiner2":{...},"finalScore":N,"arbitrated":bool}
  lastFeedbackText           String?   // Part 1: last AI feedback
  lastFeedbackLanguageErrors String?   // Part 1: JSON array of {type, original, correction, note}
  lastFeedbackAt             DateTime? // Part 1: when feedback was given
  feedbackHistory            String?   // Part 1: JSON array of history entries (v1: {grade,feedbackText,...}, v2: {finalScore,scoreBreakdown,...})
  lastRewriteParts           String?   // Part 1: JSON array of {label, text} (suggested essay)
  lastRewriteGrade           Int?      // Part 1: grade for the suggested essay
  lastRewriteReason          String?   // Part 1: why this grade for suggested essay
  lastRewriteAt              DateTime? // Part 1: when rewrite was generated
  coachingMode               String?   // "v1" | "v2" — null treated as "v1" for backward compat
  coachingPhase              String?   // v2: comprehension|outline|writing|review|feedback|revision|completed
  comprehensionData          String?   // v2: JSON {q1,q2,q3,aiCheck}
  outlineData                String?   // v2: JSON {opening,arg1,arg2,closing,aiCheck}
  selfReviewData             String?   // v2: JSON {q1..q6 booleans}
  phaseTimings               String?   // v2: JSON tracking seconds per phase
  reflectionText             String?   // v2: student's reflection from Phase 6
  @@index([userId])
  @@index([userId, part, section])
}
